# Story-to-Animation — API Keys
# Copy this file to your project directory as ".env" and fill in your key.
# (The scripts auto-create this file on first run if .env is missing.)

# Replicate API token — https://replicate.com/account/api-tokens
# Used by generate_images.py (Step 3) and generate_videos.py (Step 5).
REPLICATE_API_TOKEN=your_replicate_api_token_here
